# Public Supabase environment variables
# Option 1: Next.js prefixed (recommended)
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
# or use the publishable key alias if your project provides it:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-public-anon-key

# Option 2: Standard Supabase names (also works for server-side usage)
# SUPABASE_URL=https://your-supabase-project-url.supabase.co
# SUPABASE_ANON_KEY=your-public-anon-key
# or use the standard publishable key alias:
# SUPABASE_PUBLISHABLE_KEY=your-public-anon-key

# Optional: Custom redirect URL for auth (defaults to /auth/callback)
NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=https://www.zakaa.io/auth/callback

# Optional: Contact form integration via EmailJS
# If these are omitted, the contact form falls back to opening the visitor's email client.
# NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_xxxxxxx
# NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_xxxxxxx
# NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxx
